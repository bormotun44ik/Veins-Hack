# ─── LLM (ShadoClaw OpenProxy — no-restricts dev build) ──────
# Proxy слушает на порту 8317, Anthropic-compatible API
SHADOCLAW_BASE_URL=http://127.0.0.1:8317/v1
SHADOCLAW_API_KEY=not-required   # no-restricts версия, ключ не проверяется

# ─── Ingest ───────────────────────────────────────────────────
GITHUB_TOKEN=ghp_replace-me
GITHUB_REPO=bormotun44ik/veeins-test   # репо с живой историей команды
USE_FAKE_GITHUB=false                  # false = реальный GitHub API (рекомендуется)

# ─── Groq (Whisper транскрипция, round-robin ротация) ─────────
GROQ_API_KEY_1=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
GROQ_API_KEY_2=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
