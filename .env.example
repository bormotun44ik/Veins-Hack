# ─── LLM (ShadoClaw OpenProxy — no-restricts dev build) ──────
# Proxy слушает на порту 8317, Anthropic-compatible API
# ВАЖНО: Anthropic SDK сам добавит /v1/messages — base_url БЕЗ /v1 суффикса.
# При запуске через Docker:  http://host.docker.internal:8317
# При запуске нативно:        http://127.0.0.1:8317
# В docker-compose backend ходит к сервису shadoclaw:  http://shadoclaw:8317
SHADOCLAW_BASE_URL=http://127.0.0.1:8317
SHADOCLAW_API_KEY=not-required   # no-restricts версия, ключ не проверяется

# ─── Ingest ───────────────────────────────────────────────────
GITHUB_TOKEN=ghp_replace-me
GITHUB_REPO=bormotun44ik/veeins-test   # репо с живой историей команды
# false = реальный GitHub API (рекомендуется для dev)
# true  = fake_team.json (fallback для демо если API недоступен / rate limit)
USE_FAKE_GITHUB=false

# ─── Groq (Whisper транскрипция, round-robin ротация) ─────────
GROQ_API_KEY_1=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
GROQ_API_KEY_2=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
GROQ_API_KEY_3=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
GROQ_API_KEY_4=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
GROQ_API_KEY_5=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

# ─── Embeddings (не используются в MVP) ──────────────────────
OPENROUTER_API_KEY=sk-or-optional
GOOGLE_AI_API_KEY=optional

# ─── App ──────────────────────────────────────────────────────
DATABASE_PATH=/app/db/veins.db
DATA_DIR=/app/data
LOG_LEVEL=INFO

# Frontend → Backend
VITE_API_BASE=http://localhost:8000
VITE_MOCK=false
