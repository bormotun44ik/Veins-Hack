# ─── LLM ──────────────────────────────────────────────────────
# ShadoClaw proxy (main path). Формат совместим с Anthropic Messages API.
SHADOCLAW_BASE_URL=https://api.shadoclaw.example.com/v1
SHADOCLAW_API_KEY=sk-shado-replace-me

# Anthropic direct — используется пока ShadoClaw spec не получен.
ANTHROPIC_API_KEY=sk-ant-replace-me

# ─── Ingest ───────────────────────────────────────────────────
GITHUB_TOKEN=ghp_replace-me
GITHUB_REPO=bormotun44ik/Veins-Hack-fake-team   # используется только если USE_FAKE_GITHUB=false
USE_FAKE_GITHUB=true

GROQ_API_KEY=gsk_optional-if-re-transcribing

# ─── Embeddings (не используются в MVP, оставлены для будущего) ─
OPENROUTER_API_KEY=sk-or-optional
GOOGLE_AI_API_KEY=optional

# ─── App ──────────────────────────────────────────────────────
DATABASE_PATH=/app/db/veins.db
DATA_DIR=/app/data
LOG_LEVEL=INFO

# Frontend → Backend
VITE_API_BASE=http://localhost:8000
VITE_MOCK=false
